<?xml version="1.0" encoding="UTF-8"?>
<bot>
    <strategy>
        <name>Digit Analysis and Over/Under Predictor</name>
        <description>A trading bot that uses digit analysis for predicting over/under outcomes.</description>
        <market>Digital Options</market>
        <timeframe>60s</timeframe>
        <conditions>
            <condition>
                <type>digit</type>
                <digit>1</digit>
                <threshold>2</threshold>
            </condition>
            <condition>
                <type>over</type>
                <threshold>5</threshold>
            </condition>
            <condition>
                <type>under</type>
                <threshold>4</threshold>
            </condition>
        </conditions>
        <actions>
            <action>
                <type>buy</type>
                <option>over</option>
                <amount>10</amount>
            </action>
            <action>
                <type>buy</type>
                <option>under</option>
                <amount>10</amount>
            </action>
        </actions>
        <trading>
            <entry>
                <rule>analyzeDigits</rule>
            </entry>
        </trading>
    </strategy>
    <log>
        <entry>
            <timestamp>2026-04-21 12:31:30</timestamp>
            <message>Bot started</message>
        </entry>
    </log>
</bot>